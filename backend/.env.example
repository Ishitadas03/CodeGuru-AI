# ─── Backend Environment Variables ─────────────────────────────────────────────
# Copy this file to .env and configure for your environment.
#
# Render Deployment:
#   Set these in Render Dashboard → Environment tab
#   Set DATABASE_URL to your Supabase external connection string.
# ────────────────────────────────────────────────────────────────────────────────

# Core Security (REQUIRED in production)
SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING_MIN_32_CHARS

# Environment
ENVIRONMENT=development

# PostgreSQL via Supabase
# Supabase Dashboard → Settings → Database → Connection string → URI (external)
# Format: postgresql://postgres.xxxxx:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:6543/postgres

# Redis (optional — for caching and Celery)
REDIS_HOST=localhost
REDIS_PORT=6379

# AI Providers (at least one required in production)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_API_KEY=
OLLAMA_HOST=http://localhost:11434

# Google OAuth
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# Stripe Billing
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
STRIPE_PRO_PRICE_ID=price_REPLACE_ME
