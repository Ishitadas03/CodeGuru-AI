# ==============================================================================
# CodeGuru AI - Git Ignore Rules
# ==============================================================================

# --- Environment & Secrets ---
.env
.env.local
.env.*.local
*.env

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
*.whl

# --- Python Virtual Environments ---
.venv/
venv/
ENV/

# --- Python Testing ---
.pytest_cache/
.coverage
htmlcov/

# --- Python Tools ---
.mypy_cache/
.ruff_cache/

# --- Database Files ---
*.db
*.sqlite3
*.sqlite
backend/db/

# --- Node.js ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Next.js ---
.next/
out/

# --- TypeScript ---
*.tsbuildinfo

# --- Frontend Build ---
frontend/.next/
frontend/out/

# --- IDE / Editor ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Docker ---
# (docker-compose mounts are fine, but ignore runtime data)

# --- Monitoring Data ---
monitoring/data/
prometheus_data/
grafana_data/

# --- Misc ---
*.log
*.tmp
*.bak
*.orig
scratch_shader_test.html
