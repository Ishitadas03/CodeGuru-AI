# ==============================================================================
# CodeGuru AI - Environment Variables Specification
# ==============================================================================
#
# Deployment Platforms:
#   Frontend (Vercel):  Set NEXT_PUBLIC_API_URL in Vercel Dashboard → Settings
#   Backend  (Render):  Set all backend vars in Render Dashboard → Environment
#
# Copy this file to '.env' and fill in credentials for local development.
# ==============================================================================

# ─── Core Security (REQUIRED) ─────────────────────────────────────────────────
SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING_MIN_32_CHARS

# ─── Environment ──────────────────────────────────────────────────────────────
ENVIRONMENT=development

# ─── PostgreSQL ────────────────────────────────────────────────────────────────
# Render: auto-provided via DATABASE_URL
# Local: use individual vars or SQLite (see backend/.env)
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=codeguru

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# ─── AI Providers ──────────────────────────────────────────────────────────────
# At least one required in production
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_API_KEY=
OLLAMA_HOST=http://localhost:11434

# ─── Stripe Billing ────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
STRIPE_PRO_PRICE_ID=price_REPLACE_ME

# ─── Frontend ──────────────────────────────────────────────────────────────────
# Vercel: Set in Vercel Dashboard → Settings → Environment Variables
# Local:  http://localhost:8000/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
